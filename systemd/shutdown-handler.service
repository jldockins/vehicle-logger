[Unit]
Description=Vehicle Logger Safe Shutdown Handler
After=logger.service
Wants=logger.service

[Service]
ExecStart=/usr/bin/python3 /home/pi/vehicle-logger/shutdown_handler.py
WorkingDirectory=/home/pi/vehicle-logger
Restart=on-failure
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
